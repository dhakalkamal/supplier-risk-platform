# Supplier Risk Intelligence Platform — environment variables template.
# Copy to .env and fill in real values. Never commit a populated .env file.
#
# Usage: cp .env.example .env

# ─── Application ─────────────────────────────────────────────────────────────
# Runtime environment. Controls logging verbosity and debug features.
ENVIRONMENT=dev

# Enable FastAPI debug mode (detailed error pages). Must be false in prod.
DEBUG=true

# ─── Postgres ────────────────────────────────────────────────────────────────
# Async SQLAlchemy connection string for the operational API database.
DATABASE_URL=postgresql+asyncpg://supplier_risk:supplier_risk@localhost:5432/supplier_risk

# Postgres connection details (used by dbt and Airflow separately)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=supplier_risk
POSTGRES_PASSWORD=supplier_risk
POSTGRES_DB=supplier_risk

# ─── Kafka ───────────────────────────────────────────────────────────────────
# Comma-separated list of Kafka broker addresses.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Security protocol. Use PLAINTEXT locally, SASL_SSL in production (AWS MSK).
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ─── Redis ───────────────────────────────────────────────────────────────────
# Redis connection URL. DB 0 = production, DB 1 = tests.
REDIS_URL=redis://localhost:6379/0

# ─── SEC EDGAR ───────────────────────────────────────────────────────────────
# Required by SEC terms of service. Use your real email — fake emails risk IP ban.
# Format: "AppName your-real-email@domain.com"
SEC_EDGAR_USER_AGENT=SupplierRiskPlatform your-email@yourcompany.com

# Base URL for SEC EDGAR API. Do not change unless testing against a mirror.
SEC_EDGAR_BASE_URL=https://data.sec.gov

# Max concurrent requests to SEC EDGAR (enforced by asyncio.Semaphore).
# Do not exceed 10 — this is the SEC's published rate limit.
SEC_EDGAR_RATE_LIMIT=10

# ─── News API ────────────────────────────────────────────────────────────────
# API key from newsapi.org. Free tier = 100 req/day. Paid = unlimited.
NEWS_API_KEY=your-newsapi-key-here

# ─── Auth0 ───────────────────────────────────────────────────────────────────
# Auth0 tenant domain. Format: your-tenant.auth0.com
AUTH0_DOMAIN=your-tenant.auth0.com

# Auth0 API audience identifier. Must match what Auth0 issues in JWT.
AUTH0_AUDIENCE=https://api.supplierrisk.com

# ─── OpenAI (entity resolution fallback) ─────────────────────────────────────
# Used by entity resolution Stage 3 (LLM-assisted hard cases only).
# Max 200 calls/day enforced by LLM_RESOLUTION_DAILY_LIMIT.
OPENAI_API_KEY=sk-your-openai-key-here
LLM_RESOLUTION_DAILY_LIMIT=200
